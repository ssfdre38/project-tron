{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Tron": {
    "CollectionIntervalSeconds": 30,
    "Thresholds": {
      "CpuWarningPercent": 80,
      "CpuCriticalPercent": 95,
      "MemoryWarningPercent": 80,
      "MemoryCriticalPercent": 95,
      "DiskWarningPercent": 85,
      "DiskCriticalPercent": 95,
      "AnomalyZScoreThreshold": 3.0
    },
    "WatchedServices": {
      "Names": []
    },
    "Alerting": {
      "DiscordWebhookUrl": "",
      "MinSeverity": "Warning",
      "CooldownMinutes": 15
    },
    "Baseline": {
      "StorePath": "tron-baseline.json",
      "SaveIntervalMinutes": 5,
      "EnableAnomalyDetection": true
    },
    "Ai": {
      "EndpointUrl": "http://localhost:11435",
      "Model": "tron-model",
      "MinSeverityForAnalysis": "Warning"
    },
    "Dashboard": {
      "Enabled": true,
      "Port": 18790,
      "BindAddress": "127.0.0.1",
      "ExternalUrl": ""
    },
    "Email": {
      "Enabled": false,
      "SmtpHost": "smtp.example.com",
      "SmtpPort": 587,
      "UseSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "tron@example.com",
      "FromName": "Tron Monitor",
      "ToAddresses": [],
      "MinSeverity": "Warning"
    },
    "Webhook": {
      "Enabled": false,
      "Url": "",
      "AuthHeader": "",
      "MinSeverity": "Warning",
      "IncludeSnapshot": false
    },
    "ThreatIntel": {
      "Enabled": true,
      "BlocklistPath": "",
      "AbuseIpDbApiKey": "",
      "AbuseIpDbMinScore": 75,
      "AbuseIpDbCacheDurationMinutes": 1440
    }
  }
}
