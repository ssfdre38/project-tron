{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Tron": {
    "CollectionIntervalSeconds": 30,
    "Thresholds": {
      "CpuWarningPercent": 80,
      "CpuCriticalPercent": 95,
      "MemoryWarningPercent": 80,
      "MemoryCriticalPercent": 95,
      "DiskWarningPercent": 85,
      "DiskCriticalPercent": 95
    },
    "WatchedServices": {
      "Names": []
    },
    "Alerting": {
      "DiscordWebhookUrl": "",
      "MinSeverity": "Warning"
    }
  }
}
